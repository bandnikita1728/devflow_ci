{
  "name": "devflow-ci",
  "version": "1.0.0",
  "description": "DevFlow CI — Enterprise-grade code review assistant",
  "private": true,
  "scripts": {
    "dev": "nodemon --watch apps --ext ts --exec \"ts-node -r dotenv/config apps/api-gateway/src/index.ts\"",
    "dev:worker": "nodemon --watch apps --ext ts --exec \"ts-node -r dotenv/config apps/worker/src/worker.ts\"",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/api-gateway/src/index.js",
    "start:worker": "node dist/worker/src/worker.js",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration",
    "test:all": "jest",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "ci",
    "code-review",
    "github",
    "webhooks"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@octokit/app": "^14.1.0",
    "@octokit/rest": "19.0.13",
    "@prisma/client": "^6.19.3",
    "bullmq": "^5.78.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "opossum": "^10.0.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.3",
    "@types/opossum": "^8.1.9",
    "@types/supertest": "^7.2.0",
    "ioredis-mock": "^8.13.1",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
